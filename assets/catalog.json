{
  "agents": ["claude-code", "codex", "opencode"],
  "mcps": [
    {
      "id": "n8n-mcp",
      "label": "n8n-mcp — build & manage n8n workflows",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "n8n-mcp@latest"],
      "env": ["N8N_API_URL", "N8N_API_KEY"]
    },
    {
      "id": "figma",
      "label": "Figma — design context (OAuth on first use)",
      "transport": "http",
      "url": "https://mcp.figma.com/mcp",
      "headers": {},
      "env": []
    },
    {
      "id": "chrome-devtools",
      "label": "Chrome DevTools — inspect/debug a live browser",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"],
      "env": []
    },
    {
      "id": "pencil",
      "label": "Pencil — .pen design editor (Windows, Claude only)",
      "transport": "stdio",
      "command": "${LOCALAPPDATA}\\Programs\\Pencil\\resources\\app.asar.unpacked\\out\\mcp-server-windows-x64.exe",
      "args": ["--app", "desktop", "--agent", "claudeCodeCLI"],
      "env": [],
      "agents": ["claude-code"]
    },
    {
      "id": "puppeteer",
      "label": "Puppeteer via Smithery — browser automation",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@smithery/cli@latest", "run", "@smithery-ai/puppeteer", "--key", "${SMITHERY_KEY}"],
      "env": ["SMITHERY_KEY"],
      "agents": ["claude-code"]
    },
    {
      "id": "stitch",
      "label": "Stitch (Google) — design-to-code",
      "transport": "http",
      "url": "https://stitch.googleapis.com/mcp",
      "headers": { "X-Goog-Api-Key": "${STITCH_API_KEY}" },
      "env": ["STITCH_API_KEY"],
      "agents": ["claude-code"]
    }
  ],
  "skills": [
    {
      "id": "anti-ai-slop",
      "label": "Anti-AI-Slop — premium landing/UI design (PT)",
      "source": "local",
      "skill": "anti-ai-slop"
    },
    {
      "id": "prd",
      "label": "PRD — generate product requirements docs",
      "source": "local",
      "skill": "prd"
    },
    {
      "id": "impeccable",
      "label": "Impeccable — frontend design/UX system (v3.5.0)",
      "source": "local",
      "skill": "impeccable"
    }
  ],
  "plugins": [
    {
      "id": "claude-official",
      "label": "Claude official: context7, github, frontend-design, playwright",
      "agent": "claude-code",
      "marketplace": "anthropics/claude-plugins-official",
      "name": "claude-plugins-official",
      "install": ["context7", "github", "frontend-design", "playwright"]
    },
    {
      "id": "n8n-mcp-skills",
      "label": "n8n-mcp skills pack",
      "agent": "claude-code",
      "marketplace": "czlonkowski/n8n-skills",
      "name": "n8n-mcp-skills",
      "install": ["n8n-mcp-skills"]
    },
    {
      "id": "openai-codex",
      "label": "OpenAI Codex plugin (codex rescue/setup)",
      "agent": "claude-code",
      "marketplace": "openai/codex-plugin-cc",
      "name": "openai-codex",
      "install": ["codex"]
    },
    {
      "id": "taskmaster",
      "label": "Task Master — task orchestration",
      "agent": "claude-code",
      "marketplace": "eyaltoledano/claude-task-master",
      "name": "taskmaster",
      "install": ["taskmaster"]
    },
    {
      "id": "obsidian-skills",
      "label": "Obsidian skills (kepano)",
      "agent": "claude-code",
      "marketplace": "kepano/obsidian-skills",
      "name": "obsidian-skills",
      "install": ["obsidian"]
    },
    {
      "id": "claude-code-warp",
      "label": "Warp for Claude Code",
      "agent": "claude-code",
      "marketplace": "warpdotdev/claude-code-warp",
      "name": "claude-code-warp",
      "install": ["warp"]
    }
  ],
  "templates": {
    "claude_md": "templates/clean-code-for-agents.md",
    "agents_md": "templates/clean-code-for-agents.md",
    "memory": "templates/memory.md"
  },
  "gitignore": [
    ".claude/settings.local.json",
    ".opencode/cache/",
    ".agent-harness/"
  ]
}
